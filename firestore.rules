rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Datos públicos de solo lectura ───
    match /salons/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stylists/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stylist_services/{doc} {
      allow read, write: if request.auth != null;
    }
    
    // ─── Looks: lectura pública, escritura autenticada ───
    match /looks/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // ─── Bookings: usuarios autenticados pueden leer/escribir ───
    match /bookings/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ─── Favoritos: solo usuarios autenticados ───
    match /favorites/{doc} {
      allow read, write: if request.auth != null;
    }
    
    // ─── Usuarios: lectura autenticada, escritura solo propio perfil ───
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }
    
    // ─── Notificaciones in-app: solo lectura/escritura autenticada ───
    match /notifications/{doc} {
      allow read, write: if request.auth != null;
    }
    
    // ─── Productos/Inventario: usuarios autenticados ───
    match /products/{doc} {
      allow read, write: if request.auth != null;
    }
    
    // ─── Facturas (invoices): usuarios autenticados ───
    match /invoices/{doc} {
      allow read, write: if request.auth != null;
    }
    
    // ─── Reseñas (reviews): lectura pública, escritura autenticada ───
    match /reviews/{doc} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }
  }
}
