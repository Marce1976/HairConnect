rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Datos públicos de solo lectura ───
    match /salons/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stylists/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // ─── Looks: lectura pública, escritura autenticada ───
    match /looks/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // ─── Bookings: usuarios autenticados pueden leer/escribir ───
    match /bookings/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ─── Favoritos: cada usuario solo ve/escribe los suyos ───
    match /favorites/{doc} {
      allow read: if request.auth != null 
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ─── Usuarios: cada uno solo accede a su propio perfil ───
    match /users/{userId} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId;
    }
    
    // ─── Notificaciones in-app: solo lectura/escritura autenticada ───
    match /notifications/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
